# Supabase — récupérez ces valeurs dans votre dashboard Supabase > Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gmail OAuth2 — Google Cloud Console > APIs & Services > Credentials
# Facultatif : requis uniquement si vous utilisez l'intégration Gmail
VITE_GMAIL_CLIENT_ID=your-google-client-id
